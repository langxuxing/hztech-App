{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter (Chrome)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/flutter_app",
      "args": ["-d", "chrome"],
      "toolArgs": ["--dart-define-from-file=dart_defines/local.json"]
    },
    {
      "name": "Flutter (Android / APK)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/flutter_app",
      "args": ["-d", "android"],
      "toolArgs": ["--dart-define-from-file=dart_defines/local.json"]
    },
    {
      "name": "Flutter (debug)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/flutter_app",
      "toolArgs": ["--dart-define-from-file=dart_defines/local.json"]
    },
    {
      "name": "Flutter (profile)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "cwd": "${workspaceFolder}/flutter_app",
      "flutterMode": "profile"
    }
  ]
}
